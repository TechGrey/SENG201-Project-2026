<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<GridPane xmlns:fx="http://javafx.com/fxml/1" hgap="10.0" prefHeight="400.0" prefWidth="600.0" vgap="10.0"
          xmlns="http://javafx.com/javafx/25" fx:controller="seng201.team99.controllers.MarketTabController">
    <columnConstraints>
        <ColumnConstraints hgrow="ALWAYS" minWidth="10.0"/>
        <ColumnConstraints minWidth="10.0"/>
        <ColumnConstraints hgrow="ALWAYS" minWidth="10.0"/>
    </columnConstraints>
    <rowConstraints>
        <RowConstraints minHeight="10.0" prefHeight="40.0" vgrow="NEVER"/>
        <RowConstraints minHeight="10.0" vgrow="ALWAYS"/>
    </rowConstraints>
    <children>
        <ListView prefHeight="200.0" prefWidth="200.0" GridPane.rowIndex="1" fx:id="marketItemsListView"/>
        <ListView prefHeight="200.0" prefWidth="200.0" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
        <Label alignment="CENTER" text="Market" textAlignment="CENTER" GridPane.halignment="CENTER"
               GridPane.valignment="BOTTOM">
            <font>
                <Font name="System Bold" size="18.0"/>
            </font>
        </Label>
        <Label alignment="CENTER" layoutX="121.0" layoutY="23.0" text="Inventory" textAlignment="CENTER"
               GridPane.columnIndex="2" GridPane.halignment="CENTER" GridPane.valignment="BOTTOM">
            <font>
                <Font name="System Bold" size="18.0"/>
            </font>
        </Label>
        <VBox alignment="CENTER" prefHeight="200.0" prefWidth="100.0" spacing="10.0" GridPane.columnIndex="1"
              GridPane.halignment="CENTER" GridPane.rowIndex="1" GridPane.valignment="CENTER" GridPane.vgrow="ALWAYS">
            <children>
                <Button mnemonicParsing="false" text="Buy Item"/>
                <Button mnemonicParsing="false" text="Sell Item"/>
            </children>
        </VBox>
    </children>
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0"/>
    </padding>
</GridPane>
